[sub_resource type="GDScript" id="GDScript_fys3n"]
script/source = "extends Area2D

@onready var animated_sprite_2d: AnimatedSprite2D = $AnimatedSprite2D

# === TUNABLE ===
var idle_switch_time_min: float = 1.0
var idle_switch_time_max: float = 2.5

var squash_amount: float = 0.15      # reduced (more subtle)
var squash_speed: float = 4.0       # slower = smoother

var scale_lerp_speed: float = 8.0    # smoother blending

# === STATE ===
var idle_timer: float = 0.0
var time: float = 0.0
var is_hit: bool = false


func _ready() -> void:
	randomize()
	reset_idle_timer()
	animated_sprite_2d.play(\"idle\")


func _process(delta: float) -> void:
	time += delta
	idle_timer -= delta

	# ❌ NO squash during hit
	if is_hit:
		return

	var wave: float = sin(time * squash_speed)
	var stretch: float = wave * squash_amount

	var target_scale: Vector2 = Vector2(
		1.0 + stretch,
		1.0 - stretch
	)

	animated_sprite_2d.scale = animated_sprite_2d.scale.lerp(
		target_scale,
		scale_lerp_speed * delta
	)

	# 🎲 RANDOM IDLE SWITCH
	if idle_timer <= 0.0:
		play_random_idle()
		reset_idle_timer()


func _on_body_entered(body: Node2D) -> void:
	if is_hit:
		return

	is_hit = true

	# 🎯 play hit animation (no squash)
	animated_sprite_2d.scale = Vector2.ONE
	animated_sprite_2d.play(\"hit\")


# === HELPERS ===

func play_random_idle() -> void:
	var idles: Array[String] = [\"idle\", \"idle2\", \"idle3\"]
	var chosen: String = idles.pick_random()
	animated_sprite_2d.play(chosen)


func reset_idle_timer() -> void:
	idle_timer = randf_range(idle_switch_time_min, idle_switch_time_max)
"

